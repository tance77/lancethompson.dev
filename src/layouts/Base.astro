---
import '../styles/global.css';
import '../styles/app.css';

interface Props {
  title: string;
  description?: string;
  /** Render the floating film-grain/texture overlay (home page only). */
  grain?: boolean;
}

const { title, description = 'Lance Thompson — full-stack web developer with a front-end heart.', grain = false } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="navy" data-texture="glow">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    {grain && <div class="grain" aria-hidden="true" />}
    <slot />
    <script>
      import '../scripts/ui.ts';
    </script>
  </body>
</html>
