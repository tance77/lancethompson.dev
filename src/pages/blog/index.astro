---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import FileRow from '../../components/ui/FileRow.astro';
import Prompt from '../../components/ui/Prompt.astro';
import { postDate, publishedPosts, readTime } from '../../data/blog';

const posts = await publishedPosts();
---

<Base title="Writing" description="Notes from the build by Lance Thompson.">
  <Nav />

  <main class="relative min-h-svh overflow-hidden pt-32.5 pb-27.5">
    <div class="sec-glow sec-glow--accent" aria-hidden="true"></div>
    <div class="relative z-1 mx-auto max-w-310 px-8">
      <span class="inline-flex items-center gap-2 font-mono text-[0.813rem] tracking-[0.06em] text-accent lowercase">
        <span class="font-semibold tracking-normal">//</span>writing
      </span>
      <h1 class="mt-4.5 mb-3.5 font-display text-[clamp(30px,4.4vw,54px)] leading-[1.02] font-extrabold tracking-[-0.02em] text-balance">Notes from the build.</h1>
      <p class="mb-10 max-w-155 text-[1.063rem] text-pretty text-ink-dim">Posts on the tools, trade-offs, and decisions behind the work. Mostly Rust, the web platform, and shipping small fast things.</p>

      <Prompt class="mb-7 font-mono text-sm text-ink-dim">
        <span>ls -la ~/writing</span>
      </Prompt>

      <div class="overflow-hidden rounded-[10px] border border-hairline bg-[color-mix(in_srgb,var(--color-navy-900)_70%,#000)] font-mono">
        {posts.map((post) => <FileRow href={`/blog/${post.id}`} name={post.id} date={postDate(post.data.date)} read={readTime(post)} />)}
      </div>

      <div class="mt-6.5 flex items-baseline gap-2.5 font-mono text-[0.844rem] text-ink-faint">
        <span class="text-accent">#</span>
        <span>{posts.length} {posts.length === 1 ? 'post' : 'posts'} and counting.</span>
      </div>
    </div>
  </main>

  <Footer />
</Base>
