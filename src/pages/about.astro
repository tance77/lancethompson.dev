---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Prompt from '../components/ui/Prompt.astro';
import Reveal from '../components/ui/Reveal.astro';
import WinBar from '../components/ui/WinBar.astro';
import MetaItem from '../components/ui/MetaItem.astro';
import Tag from '../components/ui/Tag.astro';
import CommitEntry from '../components/CommitEntry.astro';
import { PORTFOLIO_DATA as data } from '../data/portfolio';

// Bio prose, shared with the home About band (see portfolio data).
const { bio, bioLd } = data;

const skillsLine = data.skills.map((g) => `${g.group}: ${g.items.join(', ')}`).join('; ');
const current = data.experience[0];
// Oldest role at the current org = true tenure start (intern, 2016).
const tenureStart = data.experience[data.experience.length - 1].span.split(' to ')[0];

// Cosmetic commit hashes for the timeline, one per role.
const hashes = ['a1f9c3e', '7b2d4e8', '3c5a9f1', 'e8d6b0a', '5f1c7d2'];
const lastRole = data.experience.length - 1;

// Wiki-style infobox rows. Order mirrors a Wikipedia person summary.
const summary: [string, string][] = [
  ['Name', data.name],
  ['Also Known As', 'Lance'],
  ['Summary', bioLd],
  ['Occupation', current.role],
  ['Current Work', `${current.org} (since ${tenureStart})`],
  ['Location', data.location],
  ['Skills', skillsLine],
  ['GitHub', data.links.github],
  ['LinkedIn', data.links.linkedin],
  ['Entity Home', data.domain],
];

// Structured data for crawlers / LLMs.
const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: data.name,
  alternateName: 'Lance',
  description: bioLd,
  url: `https://${data.domain}`,
  jobTitle: current.role,
  worksFor: { '@type': 'Organization', name: current.org },
  address: { '@type': 'PostalAddress', addressLocality: data.location },
  email: `mailto:${data.email}`,
  knowsAbout: data.skills.flatMap((g) => g.items),
  sameAs: [`https://${data.links.github}`, `https://${data.links.linkedin}`],
};
---

<Base title="About" description={bioLd}>
  <Nav />

  <main class="relative min-h-svh overflow-hidden pt-32.5 pb-27.5">
    <div class="sec-glow sec-glow--accent" aria-hidden="true"></div>
    <div class="relative z-1 mx-auto max-w-310 px-8">
      <div class="grid grid-cols-[1.15fr_0.85fr] items-center gap-12 max-[820px]:grid-cols-1 max-[820px]:gap-9">
        <div>
          <span class="inline-flex items-center gap-2 font-mono text-[0.813rem] tracking-[0.06em] text-accent lowercase">
            <span class="font-semibold tracking-normal">//</span>about
          </span>
          <h1 class="mt-4.5 mb-3.5 font-display text-[clamp(30px,4.4vw,54px)] leading-[1.02] font-extrabold tracking-[-0.02em] text-balance">
            A full-stack dev with a front-end heart.
          </h1>
          <p class="max-w-155 text-[1.063rem] text-pretty text-ink-dim">{bio}</p>

          <div class="mt-8 flex flex-wrap gap-8.5 border-t border-hairline pt-6 font-mono text-[0.813rem] text-ink-dim">
            <MetaItem label="current">{current.role}, {current.org}</MetaItem>
            <MetaItem label="since">{tenureStart}</MetaItem>
            <MetaItem label="location">{data.location}</MetaItem>
          </div>
        </div>

        <Reveal class="overflow-hidden rounded-[10px] border border-hairline bg-[color-mix(in_srgb,var(--color-navy-900)_70%,#000)] shadow-[0_30px_80px_-52px_rgba(0,0,0,0.7)] max-[820px]:max-w-95">
          <WinBar name="~/lance.png" />
          <img src="/lance.png" alt={data.name} width="640" height="640" loading="lazy" decoding="async" class="block aspect-square w-full object-cover" />
        </Reveal>
      </div>

      <!-- Stack -->
      <Reveal class="mt-18">
        <span class="inline-flex items-center gap-2 font-mono text-[0.813rem] tracking-[0.06em] text-accent lowercase">
          <span class="font-semibold tracking-normal">//</span>stack
        </span>
        <h2 class="mt-4.5 mb-8 font-display text-[clamp(24px,3.2vw,38px)] leading-[1.05] font-extrabold tracking-[-0.02em]">
          What I build with.
        </h2>
        <div class="grid grid-cols-2 gap-px overflow-hidden rounded-[10px] border border-hairline bg-hairline max-[640px]:grid-cols-1">
          {
            data.skills.map((group) => (
              <div class="bg-[color-mix(in_srgb,var(--color-navy-900)_70%,#000)] p-6">
                <span class="block font-mono text-[0.781rem] tracking-[0.04em] text-t-prop">{group.group}</span>
                <div class="mt-3.5 flex flex-wrap gap-2">
                  {group.items.map((item) => (
                    <Tag>{item}</Tag>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </Reveal>

      <!-- Experience timeline -->
      <Reveal class="mt-18">
        <span class="inline-flex items-center gap-2 font-mono text-[0.813rem] tracking-[0.06em] text-accent lowercase">
          <span class="font-semibold tracking-normal">//</span>track record
        </span>
        <h2 class="mt-4.5 mb-7 font-display text-[clamp(24px,3.2vw,38px)] leading-[1.05] font-extrabold tracking-[-0.02em]">
          Where I've been.
        </h2>
        <Prompt class="mb-7 font-mono text-sm text-ink-dim">
          <span>git log --author=lance --oneline</span>
        </Prompt>
        <div>
          {data.experience.map((experience, i) => <CommitEntry experience={experience} hash={hashes[i % hashes.length]} first={i === 0} showLine={i !== lastRole} delay={i * 60} />)}
        </div>
      </Reveal>

      <Prompt class="mt-18 mb-7 font-mono text-sm text-ink-dim">
        <span>cat ~/about/summary.json</span>
      </Prompt>

      <details
        open
        class="overflow-hidden rounded-[10px] border border-hairline bg-[color-mix(in_srgb,var(--color-navy-900)_70%,#000)] font-mono"
      >
        <summary
          class="flex cursor-pointer list-none items-center justify-between border-b border-hairline px-4 py-3 text-[0.813rem] tracking-[0.04em] text-t-str"
        >
          <span class="inline-flex items-center gap-2"><span class="text-accent">●</span> summary: for the robots</span>
          <span class="text-ink-faint">[schema.org/Person]</span>
        </summary>
        <dl class="divide-y divide-hairline text-sm">
          {
            summary.map(([label, value]) => (
              <div class="grid grid-cols-1 gap-1 px-4 py-3 sm:grid-cols-[10rem_1fr] sm:gap-4">
                <dt class="text-t-prop">{label}</dt>
                <dd class="text-pretty text-ink-dim">{value}</dd>
              </div>
            ))
          }
        </dl>
      </details>

      <div class="mt-6.5 flex items-baseline gap-2.5 font-mono text-[0.844rem] text-ink-faint">
        <span class="text-accent">#</span>
        <span>machine-readable summary above; humans, the prose says it shorter.</span>
      </div>
    </div>
  </main>

  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(personLd)} is:inline />
</Base>
