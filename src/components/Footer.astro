---
import { PORTFOLIO_DATA as data } from '../data/portfolio';

const year = new Date().getFullYear();
---

<footer class="border-t border-hairline bg-[color-mix(in_srgb,var(--color-navy-900)_60%,#000)] font-mono text-xs tracking-[0.04em] text-ink-faint">
  <div class="mx-auto flex max-w-310 items-center gap-3 px-4 py-3 sm:gap-5.5 sm:px-8">
    <span class="inline-flex shrink-0 items-center text-t-str">● main</span>
    <span class="hidden items-center truncate min-[480px]:inline-flex">{data.domain}</span>
    <span class="flex-1"></span>
    <span class="hidden items-center sm:inline-flex">UTF-8</span>
    <span class="hidden items-center sm:inline-flex">LF</span>
    <span class="inline-flex items-center whitespace-nowrap">© {year} {data.name}</span>
  </div>
</footer>
