---
// Fades/slides its slot in the first time it enters the viewport.
// JS (ui.ts) sets data-revealed on intersection.
interface Props {
  class?: string;
  delay?: number;
}
const { class: className = '', delay = 0 } = Astro.props;
---

<div
  data-reveal
  class:list={[
    'translate-y-[26px] opacity-0 transition-[opacity,transform] duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] data-[revealed]:translate-y-0 data-[revealed]:opacity-100 motion-reduce:translate-y-0 motion-reduce:opacity-100 motion-reduce:transition-none',
    className,
  ]}
  style={delay ? `transition-delay:${delay}ms` : undefined}
>
  <slot />
</div>
