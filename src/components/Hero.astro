---
import { PORTFOLIO_DATA as data } from "../data/portfolio";

const by: Record<string, string[]> = {};
data.skills.forEach((g) => {
  by[g.group] = g.items;
});
---

<section class="hero" id="top">
  <div class="hero-glow" aria-hidden="true"></div>
  <div class="hero-glow hero-glow--accent" aria-hidden="true"></div>
  <div class="wrap hero-inner">
    <div class="hero-text">
      <div class="term-line">
        <span class="term-user">lance@dev</span>
        <span class="term-path">~/portfolio</span>
        <span class="term-prompt">%</span>
        <span class="term-cmd">whoami</span>
      </div>
      <h1>
        <span class="line"><span>Lance</span></span>
        <span class="line"
          ><span>Thompson<span style="color: var(--accent)">.</span></span></span
        >
      </h1>
      <p class="hero-sub">
        {data.tagline}<span class="caret" aria-hidden="true"></span>
      </p>
      <div class="hero-cta">
        <a href="#work" class="btn btn--solid">
          <span class="btn-fn">view_work()</span> <span class="arrow">→</span>
        </a>
        <a href="#contact" class="btn"><span class="btn-fn">contact()</span></a>
      </div>
      <div class="hero-meta">
        <span><span class="k">// location</span>{data.location}</span>
        <span><span class="k">// email</span>{data.email}</span>
        <span><span class="k">// github</span>{data.links.github}</span>
      </div>
    </div>

    <div class="code-panel" data-code-panel>
      <div class="code-tabs">
        <span class="code-dots"><i></i><i></i><i></i></span>
        <button class="code-tab active" data-tab="caps">capabilities.ts</button>
        <button class="code-tab" data-tab="about">about.md</button>
        <span class="code-grow"></span>
        <span class="code-bolt"><span class="bolt"></span></span>
      </div>

      <div class="code-lines" data-view="caps">
        <div class="cl"><span class="t-com">// what I build with</span></div>
        <div class="cl">
          <span class="t-key">const</span> <span class="t-var">lance</span><span
            class="t-punc">: </span
          ><span class="t-type">Developer</span> <span class="t-punc">= &#123;</span>
        </div>
        <div class="cl ind">
          <span class="t-prop">role</span><span class="t-punc">:     </span><span
            class="t-str">"Full-Stack Web Developer"</span
          ><span class="t-punc">,</span>
        </div>
        <div class="cl ind">
          <span class="t-prop">focus</span><span class="t-punc">:    </span><span
            class="t-str">"front-end"</span
          ><span class="t-punc">,</span> <span class="t-com">// primary</span>
        </div>
        <div class="cl ind">
          <span class="t-prop">frontend</span><span class="t-punc">: [</span>{
            by["Front-end"].map((it, i) => (
              <>
                <span class="t-str">"{it}"</span>
                {i < by["Front-end"].length - 1 && <span class="t-punc">, </span>}
              </>
            ))
          }<span class="t-punc">],</span>
        </div>
        <div class="cl ind">
          <span class="t-prop">backend</span><span class="t-punc">:  [</span>{
            by["Back-end"].map((it, i) => (
              <>
                <span class="t-str">"{it}"</span>
                {i < by["Back-end"].length - 1 && <span class="t-punc">, </span>}
              </>
            ))
          }<span class="t-punc">],</span>
        </div>
        <div class="cl ind">
          <span class="t-prop">frameworks</span><span class="t-punc">: [</span>{
            by["Frameworks"].map((it, i) => (
              <>
                <span class="t-str">"{it}"</span>
                {i < by["Frameworks"].length - 1 && <span class="t-punc">, </span>}
              </>
            ))
          }<span class="t-punc">],</span>
        </div>
        <div class="cl ind">
          <span class="t-prop">cloud</span><span class="t-punc">:    [</span>{
            by["Cloud & DevOps"].map((it, i) => (
              <>
                <span class="t-str">"{it}"</span>
                {i < by["Cloud & DevOps"].length - 1 && (
                  <span class="t-punc">, </span>
                )}
              </>
            ))
          }<span class="t-punc">],</span>
        </div>
        <div class="cl ind">
          <span class="t-prop">desktop</span><span class="t-punc">:  [</span>{
            by["Desktop"].map((it, i) => (
              <>
                <span class="t-str">"{it}"</span>
                {i < by["Desktop"].length - 1 && <span class="t-punc">, </span>}
              </>
            ))
          }<span class="t-punc">],</span>
        </div>
        <div class="cl"><span class="t-punc">&#125;</span></div>
      </div>

      <div class="code-lines" data-view="about" hidden>
        <div class="cl"><span class="t-com">&lt;!-- about.md --&gt;</span></div>
        <div class="cl">
          <span class="md-d"># </span><span class="md-h">Lance Thompson</span>
        </div>
        <div class="cl">&nbsp;</div>
        <div class="cl">
          <span class="md-p">Full-stack web developer with a front-end heart.</span>
        </div>
        <div class="cl">
          <span class="md-p">I build fast, precise interfaces — and own the</span>
        </div>
        <div class="cl">
          <span class="md-p">stack behind them: PHP services, AWS infra, and</span>
        </div>
        <div class="cl">
          <span class="md-p">native desktop apps in Rust + Tauri.</span>
        </div>
        <div class="cl">&nbsp;</div>
        <div class="cl">
          <span class="md-d">- </span><span class="md-li"
            >10+ years shipping for the web</span
          >
        </div>
        <div class="cl">
          <span class="md-d">- </span><span class="md-li"
            >the bridge between design &amp; engineering</span
          >
        </div>
        <div class="cl">
          <span class="md-d">- </span><span class="md-li"
            >products, not just mockups</span
          >
        </div>
      </div>

      <div class="code-status">
        <span class="cs-accent" data-status-lang>● TypeScript</span>
        <span>UTF-8</span>
        <span>spaces: 2</span>
        <span class="cs-right" data-status-pos>Ln 9, Col 1</span>
      </div>
    </div>
  </div>
</section>
