---
import { PORTFOLIO_DATA as data } from '../data/portfolio';
import SectionHead from './ui/SectionHead.astro';
import ProjectCard from './ProjectCard.astro';
---

<section id="work" class="relative overflow-hidden py-16 md:py-27.5">
  <div class="sec-glow" aria-hidden="true"></div>
  <div class="relative z-1 mx-auto max-w-310 px-8">
    <SectionHead eyebrow="Selected work" title="Two things I built end-to-end." sub="Native desktop tools where the front-end craft and the systems work both mattered." />

    <div class="flex flex-col">
      {data.projects.map((project, i) => <ProjectCard project={project} delay={i * 40} />)}
    </div>
  </div>
</section>
