---
// One project in Selected Work: header, screenshot, blurb + problem, features, metrics, stack.
import type { Project } from '../data/portfolio';
import Reveal from './ui/Reveal.astro';
import ProjectShot from './ui/ProjectShot.astro';
import ProjectSummary from './ui/ProjectSummary.astro';
import FieldLabel from './ui/FieldLabel.astro';
import FeatureItem from './ui/FeatureItem.astro';
import Metric from './ui/Metric.astro';

interface Props {
  project: Project;
  delay?: number;
}
const { project, delay = 0 } = Astro.props;
---

<Reveal class="group border-t border-hairline py-18 first:border-t-0 first:pt-1" delay={delay}>
  <div class="mb-7.5">
    <span class="mb-3 block font-mono text-[0.781rem] text-ink-faint">
      ~/projects<span class="text-t-punc"> / </span>
      {project.id}
    </span>
    <span class="font-mono text-xs tracking-[0.16em] text-accent uppercase">{project.kicker}</span>
    <h3 class="mt-3.5 font-display text-[clamp(34px,5vw,58px)] leading-none font-extrabold tracking-[-0.03em]">{project.title}</h3>
  </div>

  <ProjectShot shot={project.shot} name={`${project.id} — ${project.kicker}`} />

  <div class="mt-10 grid grid-cols-[1.1fr_0.9fr] gap-12 max-[820px]:grid-cols-1 max-[820px]:gap-8">
    <ProjectSummary blurb={project.blurb} problem={project.problem} />
    <div class="flex flex-col gap-6.5">
      <div>
        <FieldLabel>what it does</FieldLabel>
        <ul class="flex flex-col gap-2.5">
          {project.features.map((feature) => <FeatureItem>{feature}</FeatureItem>)}
        </ul>
      </div>
      <div>
        <FieldLabel>impact</FieldLabel>
        <div class="flex flex-wrap gap-8.5">
          {project.metrics.map((metric) => <Metric metric={metric} />)}
        </div>
      </div>
      <div>
        <FieldLabel>built with</FieldLabel>
        <div class="font-mono text-[0.813rem] tracking-[0.04em] text-ink-dim">{project.stack.join('  ·  ')}</div>
      </div>
    </div>
  </div>
</Reveal>
