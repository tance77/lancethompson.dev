---
// One experience role styled as a git-log commit: hash, span, role, blurb, tags.
import type { Role } from '../data/portfolio';
import Reveal from './ui/Reveal.astro';
import TimelineDot from './ui/TimelineDot.astro';
import Tag from './ui/Tag.astro';

interface Props {
  experience: Role;
  hash: string;
  first?: boolean;
  showLine?: boolean;
  delay?: number;
}
const { experience, hash, first = false, showLine = false, delay = 0 } = Astro.props;
---

<Reveal class="grid grid-cols-[22px_1fr] gap-5 pb-8.5 last:pb-0" delay={delay}>
  <TimelineDot first={first} showLine={showLine} />
  <div>
    <div class="flex flex-wrap items-center gap-3">
      <span class="font-mono text-[0.844rem] text-accent">{hash}</span>
      {first && <span class="rounded-full border border-[color-mix(in_srgb,var(--color-t-str)_50%,transparent)] px-2 py-px font-mono text-[0.688rem] text-t-str">HEAD → main</span>}
      <span class="font-mono text-[0.781rem] text-ink-faint">{experience.span}</span>
    </div>
    <h3 class="mt-2.5 font-display text-[1.375rem] font-extrabold tracking-[-0.01em]">
      {experience.role}
      <span class="font-mono text-sm font-normal text-ink-faint">· {experience.org}</span>
    </h3>
    <p class="my-2.25 max-w-160 text-[0.938rem] text-pretty text-ink-dim">{experience.blurb}</p>
    <div class="mt-3.5 flex flex-wrap gap-2">
      {experience.tags.map((tag) => <Tag>{tag}</Tag>)}
    </div>
  </div>
</Reveal>
