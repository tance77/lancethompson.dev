---
import { PORTFOLIO_DATA as data } from '../data/portfolio';
import NavLink from './ui/NavLink.astro';

// [label, href]. Constant across pages; contact gets the accent treatment.
const links: [string, string][] = [
  ['home', '/'],
  ['about', '/about'],
  // ['blog', '/blog'],
  ['contact', '/contact'],
];
---

<nav
  data-nav
  class="group/nav fixed inset-x-0 top-0 z-50 flex items-center justify-between border-b border-transparent px-8 py-4 transition-[background,border-color,backdrop-filter] duration-300 data-open:border-hairline data-open:bg-bg data-open:backdrop-blur-[10px] data-scrolled:border-hairline data-scrolled:bg-[color-mix(in_srgb,var(--color-bg)_82%,transparent)] data-scrolled:backdrop-blur-[10px]"
>
  <a href="#top" class="flex items-center gap-3 font-display text-[1.063rem] font-extrabold tracking-[-0.01em]">
    <img src="/lance.png" alt={data.name} width="20" height="20" class="inline-block size-5 shrink-0 rounded-full object-cover" />
    <span class="font-display font-extrabold">{data.name}</span>
    <span class="ml-1 border-l border-hairline pl-3 font-mono text-[0.688rem] tracking-[0.04em] text-ink-faint max-[820px]:hidden"> ~/portfolio </span>
  </a>
  <div
    data-nav-menu
    class="flex items-center gap-7.5 max-[820px]:absolute max-[820px]:inset-x-0 max-[820px]:top-full max-[820px]:hidden max-[820px]:flex-col max-[820px]:items-start max-[820px]:gap-0 max-[820px]:divide-y max-[820px]:divide-hairline max-[820px]:border-b max-[820px]:border-hairline max-[820px]:bg-bg max-[820px]:px-8 max-[820px]:py-2 max-[820px]:backdrop-blur-[10px] group-data-open/nav:max-[820px]:flex"
  >
    {links.map(([label, href]) => <NavLink label={label} href={href} />)}
    <a
      href={`https://${data.links.github}`}
      target="_blank"
      rel="noreferrer"
      aria-label="GitHub"
      class="text-ink-dim transition-colors hover:text-ink max-[820px]:w-full max-[820px]:py-3"
    >
      <svg class="size-4.5 shrink-0" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z" />
      </svg>
    </a>
  </div>

  <button data-nav-toggle type="button" aria-label="Toggle menu" aria-expanded="false" class="hidden flex-col gap-1.5 p-1 max-[820px]:flex">
    <span class="block h-px w-5.5 bg-ink transition-transform duration-200 group-data-open/nav:translate-y-1.75 group-data-open/nav:rotate-45"></span>
    <span class="block h-px w-5.5 bg-ink transition-opacity duration-200 group-data-open/nav:opacity-0"></span>
    <span class="block h-px w-5.5 bg-ink transition-transform duration-200 group-data-open/nav:-translate-y-1.75 group-data-open/nav:-rotate-45"></span>
  </button>
</nav>
